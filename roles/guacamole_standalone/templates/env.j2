# =============================================================================
# GUACAMOLE STANDALONE - Generated by Ansible
# =============================================================================
# DO NOT EDIT MANUALLY - Managed by Ansible role guacamole_standalone

# --- Keycloak OIDC ---
KEYCLOAK_ISSUER={{ keycloak_issuer }}
OIDC_CLIENT_ID={{ guacamole_standalone_oidc_client_id }}
OIDC_CLIENT_SECRET={{ vault_guacamole_standalone_oidc_client_secret }}
PUBLIC_URL={{ guacamole_standalone_public_url }}

# --- Guacamole ---
GUACAMOLE_VERSION={{ guacamole_standalone_version }}
POSTGRES_VERSION={{ guacamole_standalone_postgres_version }}
GUACAMOLE_DB_PASSWORD={{ guacamole_standalone_db_password }}
JSON_SECRET_KEY={{ guacamole_standalone_json_secret_key }}

# --- JVM Tomcat ---
JAVA_XMS={{ guacamole_standalone_java_xms }}
JAVA_XMX={{ guacamole_standalone_java_xmx }}
JAVA_GC={{ guacamole_standalone_java_gc }}

# --- Credential Vault ---
VAULT_ENCRYPTION_KEY={{ guacamole_standalone_vault_encryption_key }}
CREDENTIALS_EXPIRY_HOURS={{ guacamole_standalone_credentials_expiry_hours }}

# --- Session ---
SESSION_SECRET={{ guacamole_standalone_session_secret }}

# --- Chemins ---
DATA_DIR={{ guacamole_standalone_data_dir }}
SAVE_DIR={{ guacamole_standalone_save_dir }}

# --- Logs ---
LOG_LEVEL={{ guacamole_standalone_log_level }}
LOG_MAX_SIZE={{ guacamole_standalone_log_max_size }}
LOG_MAX_FILE={{ guacamole_standalone_log_max_file }}
GUACD_LOG_LEVEL={{ guacamole_standalone_guacd_log_level }}

# --- Reseau ---
DOMAIN={{ domain }}
PORTAL_HTTP_PORT={{ guacamole_standalone_portal_port }}
GUACAMOLE_HTTP_PORT={{ guacamole_standalone_guacamole_port }}
