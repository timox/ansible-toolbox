# Guacamole Standalone - Configuration
# Extensions: JSON Auth (credential injection) + OIDC (fallback) + JDBC (connections DB)
# Generated by Ansible role guacamole_standalone

# === PostgreSQL ===
postgresql-hostname: guacamole-db
postgresql-port: 5432
postgresql-database: {{ guacamole_standalone_db_name }}
postgresql-username: {{ guacamole_standalone_db_user }}
postgresql-password: {{ guacamole_standalone_db_password }}
postgresql-max-connections: {{ guacamole_standalone_postgres_max_connections }}
postgresql-max-connections-per-user: {{ guacamole_standalone_postgres_max_connections_per_user }}

# === guacd ===
guacd-hostname: guacamole-daemon
guacd-port: 4822

# === JSON Auth (credential injection from guac-portal) ===
json-secret-key: {{ guacamole_standalone_json_secret_key }}
json-trusted-networks: 172.16.0.0/12, 10.0.0.0/8, 192.168.0.0/16

# === OpenID Connect (direct SSO fallback) ===
openid-authorization-endpoint: {{ keycloak_issuer }}/protocol/openid-connect/auth
openid-jwks-endpoint: {{ keycloak_issuer }}/protocol/openid-connect/certs
openid-issuer: {{ keycloak_issuer }}
openid-client-id: {{ guacamole_standalone_oidc_client_id }}
openid-redirect-uri: {{ guacamole_standalone_public_url }}/guacamole/
openid-username-claim-type: {{ guacamole_standalone_oidc_username_claim }}
openid-groups-claim-type: {{ guacamole_standalone_oidc_groups_claim }}
openid-scope: {{ guacamole_standalone_oidc_scope }}
openid-allowed-clock-skew: {{ guacamole_standalone_oidc_allowed_clock_skew }}
openid-max-token-validity: {{ guacamole_standalone_oidc_max_token_validity }}

# === Extensions Priority ===
# JSON first (portal injection), then OIDC (direct access), then JDBC (DB storage)
extension-priority: {{ guacamole_standalone_extension_priority }}

# === WebSocket and Session ===
enable-websocket: {{ guacamole_standalone_enable_websocket | lower }}
api-session-timeout: {{ guacamole_standalone_api_session_timeout }}

# === Drive and Recording ===
recording-search-path: /record
create-recording-path: true
drive-path: /drive
create-drive-path: true

# === UI ===
available-languages: {{ guacamole_standalone_available_languages }}
skip-if-unavailable: postgresql
